func createMovieJSON(id int, nm Movie) {
    path := fmt.Sprintf("database/movies/%d.json", id)

    movie := map[string]any{
        "id": id,
        "creator_fsid": nm.AuFSID,
        "creator_name": nm.AuName,
        "filename": nm.AuFN,
        "stars": map[string]int{
            "yellow": 0,
            "green": 0,
            "red": 0,
            "blue": 0,
            "purple": 0,
        },
        "comments": 0,
        "views": 0,
        "downloads": 0,
        "last_updated": nm.LastMod.String(),
        "channels": []int{nm.ChannelID},
    }

    data, _ := json.MarshalIndent(movie, "", "  ")
    os.WriteFile(path, data, 0644)
}
